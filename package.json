{
  "name": "lifetrack",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "api",
    "mobile"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "test:api": "npm run test --workspace=api",
    "test:mobile": "npm run test --workspace=mobile",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .prettierignore"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.1.3",
    "prettier": "3.2.5",
    "typescript": "5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "bcrypt": "6.0.0",
    "bullmq": "5.80.2",
    "expo": "57.0.4",
    "express": "4.22.2",
    "react-native": "0.84.1"
  }
}
